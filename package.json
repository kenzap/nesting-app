{
  "name": "nesting-app",
  "version": "1.0.0",
  "description": "DXF Nesting Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist:win": "electron-builder --win nsis",
    "dist:win-portable": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "@flatten-js/core": "^1.6.12",
    "concaveman": "^2.0.0",
    "dxf-parser": "^1.1.2",
    "jsts": "^2.12.1",
    "makerjs": "^0.18.2",
    "planar-face-discovery": "^2.0.7",
    "to-planar-graph": "^3.0.1"
  },
  "build": {
    "appId": "com.kenzap.nesting",
    "productName": "KENZAP NEST",
    "files": [
      "main.js",
      "main/**/*",
      "preload.js",
      "package.json",
      "renderer/**/*",
      "shared/**/*",
      "assets/**/*",
      "native/**/*"
    ],
    "extraResources": [
      {
        "from": "native",
        "to": "native",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "icon": "assets/icon-square.ico",
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "mac": {
      "icon": "assets/icon-square.icns"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
